generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  SALES
  PM
  RD
  FINANCE
}

enum PipelineStatus {
  POTENTIAL
  CONTACTING
  QUOTATION
  WON
  LOST
}

enum PipelineType {
  NEW_DEVELOPMENT
  MAINTENANCE
  CONSULTING
  OTHER
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum ProjectStatus {
  PLANNING
  EXECUTING
  ACCEPTANCE
  CLOSED
}

enum TaskStatus {
  TODO
  DOING
  REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TransferType {
  NORMAL
  HOLIDAY
  ADDITIONAL
  ADJUSTMENT
}

enum WorkOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  password     String
  name         String
  role         Role      @default(SALES)
  refreshToken String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  ownedPipelines  Pipeline[]  @relation("PipelineOwner")
  managedProjects Project[]   @relation("ProjectManager")
  assignedTasks   Task[]      @relation("TaskAssignee")
  workOrders      WorkOrder[] @relation("WorkOrderEngineer")
  transfers       Transfer[]  @relation("TransferCreator")
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  taxId     String?
  contact   String?
  phone     String?
  email     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pipelines  Pipeline[]
  workOrders WorkOrder[]
}

model Pipeline {
  id              String         @id @default(cuid())
  customerId      String
  title           String
  type            PipelineType   @default(OTHER)
  cost            Decimal        @db.Decimal(15, 2)
  successRate     Int            @default(50)
  expectedRevenue Decimal        @db.Decimal(15, 2)
  status          PipelineStatus @default(POTENTIAL)
  ownerId         String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  customer   Customer    @relation(fields: [customerId], references: [id])
  owner      User        @relation("PipelineOwner", fields: [ownerId], references: [id])
  quotations Quotation[]
}

model Quotation {
  id           String          @id @default(cuid())
  pipelineId   String
  version      Int             @default(1)
  paymentTerms String?
  totalPrice   Decimal         @db.Decimal(15, 2)
  status       QuotationStatus @default(DRAFT)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  pipeline     Pipeline        @relation(fields: [pipelineId], references: [id])
  items        QuotationItem[]
  internalCost InternalCost?
  project      Project?
}

model QuotationItem {
  id          String  @id @default(cuid())
  quotationId String
  name        String
  description String?
  unitPrice   Decimal @db.Decimal(15, 2)
  manDay      Decimal @db.Decimal(10, 2) @default(0)
  amount      Decimal @db.Decimal(15, 2)

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

model InternalCost {
  id          String  @id @default(cuid())
  quotationId String  @unique
  labor       Decimal @db.Decimal(15, 2) @default(0)
  travel      Decimal @db.Decimal(15, 2) @default(0)
  risk        Decimal @db.Decimal(15, 2) @default(0)
  misc        Decimal @db.Decimal(15, 2) @default(0)

  quotation Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
}

model Project {
  id          String        @id @default(cuid())
  quotationId String        @unique
  managerId   String
  status      ProjectStatus @default(PLANNING)
  startDate   DateTime?
  endDate     DateTime?
  income      Decimal       @db.Decimal(15, 2) @default(0)
  cost        Decimal       @db.Decimal(15, 2) @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  quotation  Quotation   @relation(fields: [quotationId], references: [id])
  manager    User        @relation("ProjectManager", fields: [managerId], references: [id])
  tasks      Task[]
  workOrders WorkOrder[]
  transfers  Transfer[]
}

model Task {
  id          String       @id @default(cuid())
  projectId   String
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  assigneeId  String?
  workHour    Decimal      @db.Decimal(10, 2) @default(0)
  dueDate     DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])
}

model WorkOrder {
  id                String          @id @default(cuid())
  projectId         String
  customerId        String
  serviceDate       DateTime
  description       String
  engineerId        String
  attachmentUrl     String?
  customerSignature String?
  status            WorkOrderStatus @default(DRAFT)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id])
  engineer User     @relation("WorkOrderEngineer", fields: [engineerId], references: [id])
}

model Transfer {
  id        String       @id @default(cuid())
  projectId String
  amount    Decimal      @db.Decimal(15, 2)
  type      TransferType @default(NORMAL)
  date      DateTime     @default(now())
  remark    String?
  createdBy String
  createdAt DateTime     @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator User    @relation("TransferCreator", fields: [createdBy], references: [id])
}
