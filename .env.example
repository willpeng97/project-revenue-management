# Database (PostgreSQL, e.g. Neon)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# Clerk (authentication provider for Microsoft Entra ID SSO)
# Get these from https://dashboard.clerk.com → API keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"

# Clerk routing: keep the sign-in surface on /login
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/login"

# Microsoft Entra ID tenant restriction
# Only users from this Entra tenant may sign in. Required in production.
MICROSOFT_TENANT_ID="00000000-0000-0000-0000-000000000000"

# Allowed company email domain (defaults to systexsoftware.com.tw if unset)
ALLOWED_EMAIL_DOMAIN="systexsoftware.com.tw"
